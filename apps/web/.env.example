# Get a free Unsplash API key at https://unsplash.com/developers
# Create an app, copy the "Access Key", and paste it here.
VITE_UNSPLASH_ACCESS_KEY=your_access_key_here

# Get a free Pexels API key at https://www.pexels.com/api/new/
# Create an account, request API access, and paste your key here.
VITE_PEXELS_API_KEY=your_pexels_key_here

# Note: The Anthropic API key for AI template generation is NOT stored
# here. Users connect their own Claude account directly in the app
# (Settings → Connect Claude). The key is stored in localStorage only.
